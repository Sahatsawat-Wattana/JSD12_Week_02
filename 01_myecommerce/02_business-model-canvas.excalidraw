      "isDeleted": false,
      "boundElements": null,
      "updated": 1773120369839,
      "link": null,
      "locked": false,
      "text": "The online bookstore\nprovides convenient access\nto a wide variety of books\nanytime and anywhere.\nCustomers can easily search\nfor books, compare prices,\nread reviews, and receive\nbooks delivered to their\nhomes.",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The online bookstore provides convenient access to a wide variety of books anytime and anywhere. Customers can easily search for books, compare prices, read reviews, and receive books delivered to their homes.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "ZqIMxtQVYMwjq5jBVifYx",
