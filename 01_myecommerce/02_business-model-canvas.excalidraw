      "isDeleted": false,
      "boundElements": null,
      "updated": 1773120488989,
      "link": null,
      "locked": false,
      "text": "The target customers\ninclude students, teachers,\nresearchers, book lovers,\nand general readers who\nprefer buying books online.\nIt also targets customers\nwho do not have easy\naccess to physical\nbookstores and prefer the\nconvenience of home\ndelivery.",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The target customers include students, teachers, researchers, book lovers, and general readers who prefer buying books online. It also targets customers who do not have easy access to physical bookstores and prefer the convenience of home delivery.",
      "autoResize": false,
      "lineHeight": 1.25
    },
