      "updated": 1773120254069,
      "link": null,
      "locked": false,
      "text": "The bookstore partners\nwith book publishers,\ndistributors, payment\ngateway providers,\ndelivery and logistics\ncompanies, and\ntechnology providers\nwho support the\nwebsite or platform.",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The bookstore partners with book publishers, distributors, payment gateway providers, delivery and logistics companies, and technology providers who support the website or platform.",
