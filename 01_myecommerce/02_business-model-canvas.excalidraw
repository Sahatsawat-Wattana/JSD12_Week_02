      "boundElements": null,
      "updated": 1773120444329,
      "link": null,
      "locked": false,
      "text": "The business reaches\ncustomers through its e-\ncommerce website, mobile\napplication, social media\nplatforms, email\nmarketing, and online\nadvertisements. Delivery\nservices and logistics\npartners are also\nchannels for getting the\nproduct to the customer.",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The business reaches customers through its e-commerce website, mobile application, social media platforms, email marketing, and online advertisements. Delivery services and logistics partners are also channels for getting the product to the customer.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
