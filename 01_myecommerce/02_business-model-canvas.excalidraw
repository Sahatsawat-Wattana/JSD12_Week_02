      "isDeleted": false,
      "boundElements": null,
      "updated": 1773120406743,
      "link": null,
      "locked": false,
      "text": "Customer relationships are\nmaintained through\npersonalized\nrecommendations,\ncustomer support, loyalty\nprograms, newsletters, and\nresponsive online service\nsuch as chat support or\nemail assistance.",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Customer relationships are maintained through personalized recommendations, customer support, loyalty programs, newsletters, and responsive online service such as chat support or email assistance.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "MMlMIJ8eqqtwRt90JfcDF",
      "type": "text",
